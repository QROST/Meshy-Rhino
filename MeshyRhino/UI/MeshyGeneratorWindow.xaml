<Window x:Class="MeshyRhino.UI.MeshyGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meshy 3D Generator" Height="780" Width="540"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#2D7DD2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B0B0B0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B5EA0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Top bar: title + settings -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="Settings" Width="70" Height="28"
                    Click="SettingsButton_Click"/>
            <TextBlock Text="Meshy 3D Generator" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Bottom: thumbnail + progress + status -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <!-- Thumbnail preview -->
            <Border x:Name="ThumbnailBorder" Visibility="Collapsed"
                    BorderBrush="#DDD" BorderThickness="1" CornerRadius="4"
                    HorizontalAlignment="Center" Margin="0,0,0,8"
                    Background="#FFF">
                <Image x:Name="ThumbnailImage" Width="160" Height="160"
                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <DockPanel>
                <Button x:Name="BtnCancel" DockPanel.Dock="Right" Content="Cancel"
                        Width="70" Height="20" Margin="8,0,0,0"
                        Click="BtnCancel_Click" Visibility="Collapsed"
                        Background="#D9534F" Foreground="White" FontSize="11"
                        FontWeight="SemiBold" Cursor="Hand"/>
                <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
            </DockPanel>
            <TextBlock x:Name="StatusText" Text="Ready" Margin="0,4,0,0"
                       Foreground="#666" FontSize="11"/>
        </StackPanel>

        <!-- Shared options panel -->
        <GroupBox DockPanel.Dock="Bottom" Header="Output &amp; Options" Margin="0,8,0,0" Padding="8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Placement" Style="{StaticResource SectionLabel}"/>
                        <RadioButton x:Name="RbMesh" Content="Mesh Object" IsChecked="True"
                                     GroupName="Placement" Margin="0,2"/>
                        <RadioButton x:Name="RbBlock" Content="Block Instance" GroupName="Placement"
                                     Margin="0,2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="AI Model" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CbAiModel" SelectedIndex="0">
                            <ComboBoxItem Content="Meshy-6 (Latest)" Tag="latest"/>
                            <ComboBoxItem Content="Meshy-5" Tag="meshy-5"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Topology" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CbTopology" SelectedIndex="0">
                            <ComboBoxItem Content="Triangle" Tag="triangle"/>
                            <ComboBoxItem Content="Quad" Tag="quad"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Target Polycount" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TbPolycount" Text="30000"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Format" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CbFormat" SelectedIndex="0" SelectionChanged="CbFormat_SelectionChanged">
                            <ComboBoxItem Content="GLB (Native Import)" Tag="glb"/>
                            <ComboBoxItem Content="OBJ (Custom Parser)" Tag="obj"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Model Type" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CbModelType" SelectedIndex="0">
                            <ComboBoxItem Content="Standard" Tag="standard"/>
                            <ComboBoxItem Content="Low Poly" Tag="lowpoly"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Symmetry" Style="{StaticResource SectionLabel}"/>
                        <ComboBox x:Name="CbSymmetry" SelectedIndex="0">
                            <ComboBoxItem Content="Auto" Tag="auto"/>
                            <ComboBoxItem Content="On" Tag="on"/>
                            <ComboBoxItem Content="Off" Tag="off"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <CheckBox x:Name="CbPbr" Content="Enable PBR maps" Margin="0,24,0,0"/>
                        <CheckBox x:Name="CbRemoveLighting" Content="Remove lighting" Margin="0,6,0,0"
                                  ToolTip="Remove highlights/shadows for cleaner results under custom lighting"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Tab control -->
        <TabControl Margin="0,4,0,0">

            <!-- Text-to-3D Tab -->
            <TabItem Header="Text-to-3D">
                <StackPanel Margin="12">
                    <TextBlock Text="Text Prompt" Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="TbTextPrompt" Height="80" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             MaxLength="600"/>
                    <TextBlock Text="Max 600 characters. Describe the 3D object you want to generate."
                               Foreground="#999" FontSize="10" Margin="0,2,0,0"/>

                    <TextBlock Text="Texture Prompt (optional, for refine step)"
                               Style="{StaticResource SectionLabel}"/>
                    <TextBox x:Name="TbTexturePrompt" Height="40" TextWrapping="Wrap"
                             MaxLength="600"/>

                    <CheckBox x:Name="CbSkipRefine" Content="Preview only (skip refine)"
                              Margin="0,8,0,0"
                              ToolTip="Generate a preview mesh without texturing. Faster and cheaper."/>

                    <Button Content="Generate (Preview + Refine)" Margin="0,12,0,0"
                            Style="{StaticResource ActionButton}"
                            x:Name="BtnTextGenerate" Click="BtnTextGenerate_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Image-to-3D Tab -->
            <TabItem Header="Image-to-3D">
                <StackPanel Margin="12">
                    <TextBlock Text="Image" Style="{StaticResource SectionLabel}"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Height="28"
                                Margin="8,0,0,0" Click="BtnBrowseImage_Click"/>
                        <TextBox x:Name="TbImagePath" IsReadOnly="True"/>
                    </DockPanel>
                    <TextBlock Text="Select a .jpg or .png image, or paste a public URL"
                               Foreground="#999" FontSize="10" Margin="0,2,0,0"/>

                    <TextBox x:Name="TbImageUrl" Margin="0,8,0,0"
                             Text="" ToolTip="Or paste a public image URL here"/>

                    <CheckBox x:Name="CbShouldTexture" Content="Generate texture" IsChecked="True"
                              Margin="0,8,0,0"/>

                    <Button Content="Generate" Margin="0,12,0,0"
                            Style="{StaticResource ActionButton}"
                            x:Name="BtnImageGenerate" Click="BtnImageGenerate_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Multi-Image-to-3D Tab -->
            <TabItem Header="Multi-Image-to-3D">
                <StackPanel Margin="12">
                    <TextBlock Text="Images (1-4, same object from different angles)"
                               Style="{StaticResource SectionLabel}"/>
                    <ListBox x:Name="LbMultiImages" Height="120"
                             SelectionMode="Single"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Add Image..." Width="90" Height="28"
                                Click="BtnAddMultiImage_Click"/>
                        <Button Content="Remove" Width="70" Height="28" Margin="8,0,0,0"
                                Click="BtnRemoveMultiImage_Click"/>
                    </StackPanel>

                    <CheckBox x:Name="CbMultiShouldTexture" Content="Generate texture"
                              IsChecked="True" Margin="0,8,0,0"/>

                    <Button Content="Generate" Margin="0,12,0,0"
                            Style="{StaticResource ActionButton}"
                            x:Name="BtnMultiGenerate" Click="BtnMultiGenerate_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Text-to-Texture Tab -->
            <TabItem Header="Text-to-Texture">
                <StackPanel Margin="12">
                    <TextBlock Text="Source Model" Style="{StaticResource SectionLabel}"/>
                    <RadioButton x:Name="RbRetextureTaskId" Content="From previous Meshy task ID"
                                 GroupName="RetextureSource" IsChecked="True" Margin="0,2"/>
                    <TextBox x:Name="TbRetextureTaskId" Margin="20,4,0,0"
                             ToolTip="Task ID from a completed Text-to-3D or Image-to-3D generation"/>

                    <RadioButton x:Name="RbRetextureFile" Content="From model file (.glb, .obj, .fbx, .stl)"
                                 GroupName="RetextureSource" Margin="0,6"/>
                    <DockPanel Margin="20,4,0,0">
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Height="28"
                                Margin="8,0,0,0" Click="BtnBrowseRetextureModel_Click"/>
                        <TextBox x:Name="TbRetextureModelPath" IsReadOnly="True"/>
                    </DockPanel>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="Style Source" Style="{StaticResource SectionLabel}"/>
                    <RadioButton x:Name="RbRetextureByText" Content="Text prompt"
                                 GroupName="RetextureStyle" IsChecked="True" Margin="0,2"/>
                    <TextBox x:Name="TbRetexturePrompt" Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True" Margin="20,4,0,0" MaxLength="600"/>

                    <RadioButton x:Name="RbRetextureByImage" Content="Reference image"
                                 GroupName="RetextureStyle" Margin="0,6"/>
                    <DockPanel Margin="20,4,0,0">
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Height="28"
                                Margin="8,0,0,0" Click="BtnBrowseRetextureImage_Click"/>
                        <TextBox x:Name="TbRetextureImagePath" IsReadOnly="True"/>
                    </DockPanel>

                    <CheckBox x:Name="CbRetextureOriginalUv" Content="Preserve original UVs"
                              IsChecked="True" Margin="0,8,0,0"/>

                    <Button Content="Retexture" Margin="0,12,0,0"
                            Style="{StaticResource ActionButton}"
                            x:Name="BtnRetexture" Click="BtnRetexture_Click"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
