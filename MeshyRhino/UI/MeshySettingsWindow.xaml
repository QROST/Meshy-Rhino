<Window x:Class="MeshyRhino.UI.MeshySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meshy Settings" Height="220" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Meshy API Key" FontWeight="SemiBold" FontSize="14"/>

        <TextBlock Grid.Row="2" Text="Enter your Meshy API key (starts with msy_). You can get one at meshy.ai/settings/api"
                   TextWrapping="Wrap" Foreground="#666" FontSize="11"/>

        <TextBox Grid.Row="4" x:Name="ApiKeyTextBox" FontSize="13" Padding="6,4"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save" Width="80" Height="30"
                    Click="SaveButton_Click" IsDefault="True"
                    Background="#2D7DD2" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
